#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# Auto-fix formatting and linting on staged Python files.
# lint-staged stashes unstaged changes so only staged content is processed.
npx lint-staged

# Apply terminal control sequences in staged Marimo output before committing.
mapfile -t STAGED < <(
    git diff --cached --name-only --diff-filter=ACM \
    | grep -E '^docs/__marimo__/(.*\.html|session/.*\.py\.json)$' \
    || true
)

if [[ ${#STAGED[@]} -gt 0 ]]; then
    echo 'Cleaning Marimo console output...'
    uv run --no-sync python scripts/clean_docs.py "${STAGED[@]}"
    git add -- "${STAGED[@]}"
fi
