{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "sandbox": {
        "network": {
            "allowedDomains": [
                "*.pytorch.org",
                "storage.googleapis.com", // JAX
                "modal.com",
                "*.modal.com",
                "*.modal.run", // API
                "*.modal-storage.com" // Volumes
            ]
        }
    },
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
                    }
                ]
            }
        ]
    }
}
